#!ipxe

# Set the hostname for the installer environment
set hostname w05

echo ${rand}
sleep 5

# Include the main Debian installer configuration for the Dell Wyse 5070 device
chain --autofree ${gh_url}/dell.wyse.5070.ipxe?${rand} || goto fallback

:fallback
echo "Error: Unable to load boot configuration from ${gh_url} for the Dell Wyse 3040 device."
echo "Please check the network connection and the availability of the configuration files."
sleep 15
reboot